# Neutrdice Docker 环境变量配置示例
# 复制此文件为 .env 并修改对应值

# ===== 项目名称（用于容器和数据卷命名） =====
COMPOSE_PROJECT_NAME=docker-3001

# ===== 面板配置 =====
PANEL_PORT=3001
PANEL_PASSWORD=neutrdice2024

# ===== 镜像版本（用于 Watchtower 更新） =====
# 格式: v2026-06-29-39b0401
# 或者使用 latest
PANEL_VERSION=v2026-06-29-39b0401

# ===== GitHub 仓库（用于版本检测和镜像拉取） =====
# 格式: owner/repo
GITHUB_REPO=xiaogouyo/neutrdice_webui

# ===== 端口配置 =====
FRONTEND_PORT=3000
SEALDICE_PORT1=32110
SEALDICE_PORT2=32111
NAPCAT_PORT1=3002
NAPCAT_PORT2=3003
NAPCAT_PORT3=6099
